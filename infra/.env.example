# Core shared secrets
JWT_SECRET=replace_with_a_long_random_secret
INTERNAL_RPC_TOKEN=replace_with_internal_rpc_token

# Postgres bootstrap
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_DB=platform

# Service database passwords
AUTH_DB_PASSWORD=replace_with_auth_db_password
INVENTORY_DB_PASSWORD=replace_with_inventory_db_password
ORDER_DB_PASSWORD=replace_with_order_db_password
PAYMENT_DB_PASSWORD=replace_with_payment_db_password
NOTIFICATION_DB_PASSWORD=replace_with_notification_db_password

# Auth service integrations
MAIL_USERNAME=
MAIL_PASSWORD=

# Cloudinary (auth-service + inventory-service)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_SECURE=true
PRODUCT_IMAGE_MAX_SIZE_BYTES=5242880
PRODUCT_IMAGE_MAX_REQUEST_SIZE_BYTES=6291456

# Payment service integrations
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# API gateway CORS
# Add all origins that can open frontend, separated by comma.
# Example includes localhost, LAN IP and public IP pattern.
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,http://10.*.*.*:5173,http://192.168.*.*:5173,http://172.16.*.*:5173,http://172.17.*.*:5173,http://172.18.*.*:5173,http://172.19.*.*:5173,http://172.2*.*.*:5173,http://172.30.*.*:5173,http://172.31.*.*:5173,http://YOUR_PUBLIC_IP:5173

# Realtime product review topics (optional override)
TOPIC_PRODUCT_REVIEW_CREATED=product.review.created.v1
TOPIC_PRODUCT_REVIEW_UPDATED=product.review.updated.v1
TOPIC_PRODUCT_REVIEW_COMMENT_CREATED=product.review.comment.created.v1
